# LLM provider configuration
# Set LLM_PROVIDER to "openai" or "anthropic" (Vercel AI SDK).
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=

# Optional model overrides (defaults are gpt-4o-mini for OpenAI,
# claude-haiku-4-5-20251001 for Anthropic).
LLM_CHAT_MODEL=
LLM_CLASSIFIER_MODEL=
LLM_AUDIT_MODEL=

# Pseudonymisation salt for HMAC-SHA256 hashing of learner IDs.
# Generate 32 bytes of randomness, e.g. `openssl rand -hex 32`.
#
# Salt-rotation policy (per deployment): rotating this value starts a new
# pseudonymisation epoch. Existing learner_hash values were derived from the
# previous salt, so after rotation old and new rows can no longer be linked to
# the same learner. The retention window below bounds how long any pre-rotation
# rows survive. Rotate on a fixed cadence (e.g. each term) or on suspected
# exposure; there is no automated cryptographic re-keying of historical hashes.
PSEUDONYM_SALT=replace-with-32-bytes-of-randomness

# Log retention. The daily /api/cron/cleanup job deletes interaction and audit
# rows older than RETENTION_DAYS (default 90). CRON_SECRET authenticates the
# Vercel cron invocation; generate with `openssl rand -hex 32`. If CRON_SECRET
# is unset the purge endpoint refuses to run.
RETENTION_DAYS=90
CRON_SECRET=

# Vercel Postgres (Neon). Pulled automatically with `vercel env pull`.
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=

# Vercel KV (optional, for ephemeral session state).
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# Auth.js v5 core config. Tutor sign-in uses the Credentials provider
# (ADMIN_EMAIL + ADMIN_PASSWORD_HASH, configured below).
# AUTH_SECRET: generate with `openssl rand -hex 32`
# AUTH_URL: the public origin of the deployment (no trailing slash)
AUTH_SECRET=
AUTH_URL=https://llmlearnfair.vercel.app

# Single-tutor admin credentials (Auth.js Credentials provider).
# ADMIN_EMAIL is what the tutor types in the email field; defaults to "admin".
# ADMIN_PASSWORD_HASH is a bcrypt hash. Generate via:
#   pnpm change-admin-password
# That script prompts for a plaintext password, hashes it locally, and pushes
# the hash to Vercel via `vercel env add` (never echoed to the terminal).
#
# IMPORTANT for local .env files: a bcrypt hash contains literal "$" sequences
# ($2b$12$...). Next.js loads .env via dotenv-expand, which treats $name as a
# variable reference and will silently corrupt the hash (login then always
# fails). Escape every "$" as "\$" when pasting a hash into .env.local, e.g.
#   ADMIN_PASSWORD_HASH="\$2b\$12\$abcdef..."
# Vercel-managed env vars are injected directly and need no escaping.
ADMIN_EMAIL=admin
ADMIN_PASSWORD_HASH=
